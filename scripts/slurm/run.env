# Shared runtime configuration for Bridge Engine Phase 1 Slurm jobs.
# Edit these values before launch.

# Training identity
export RUN_NAME=${RUN_NAME:-trinity_smolvla_$(date +%Y%m%d_%H%M%S)}
export OUTPUT_ROOT=${OUTPUT_ROOT:-/mnt/sharefs/$USER/bridge_engine_runs}

# Policy / datasets  (use separate vars – draccus needs repeated CLI args)
export POLICY_TYPE=${POLICY_TYPE:-smolvla}
export DATASET_REPO_1=${DATASET_REPO_1:-lerobot/aloha_mobile_cabinet}
export DATASET_REPO_2=${DATASET_REPO_2:-lerobot/svla_so100_sorting}
export DATASET_REPO_3=${DATASET_REPO_3:-lerobot/svla_so100_pickplace}
export SAMPLING_WEIGHT_1=${SAMPLING_WEIGHT_1:-0.5}
export SAMPLING_WEIGHT_2=${SAMPLING_WEIGHT_2:-0.3}
export SAMPLING_WEIGHT_3=${SAMPLING_WEIGHT_3:-0.2}

# Core train hyperparams (deadline-first defaults)
export BATCH_SIZE=${BATCH_SIZE:-64}
export TRAIN_STEPS=${TRAIN_STEPS:-120000}
export SAVE_FREQ=${SAVE_FREQ:-5000}
export SCHEDULER_DECAY_STEPS=${SCHEDULER_DECAY_STEPS:-120000}
export NUM_PROCESSES=${NUM_PROCESSES:-8}
export RESUME=${RESUME:-false}
export RESUME_RUN_DIR=${RESUME_RUN_DIR:-}
export RESUME_CHECKPOINT=${RESUME_CHECKPOINT:-last}

# Optional runtime hooks
export WANDB_ENABLE=${WANDB_ENABLE:-true}
export WANDB_PROJECT=${WANDB_PROJECT:-bridge-engine}
export HF_HOME=${HF_HOME:-/mnt/sharefs/$USER/.cache/huggingface}
export TMPDIR=${TMPDIR:-/tmp}

# Optional evaluation command override.
# If empty, eval_and_validate.sh performs checkpoint validation only.
# Example:
# export EVAL_COMMAND='lerobot-eval --policy.path="$CHECKPOINT_DIR" --some.flag=value'
export EVAL_COMMAND=${EVAL_COMMAND:-}
